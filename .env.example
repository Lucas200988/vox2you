# ─── Supabase Database ───────────────────────────────────────────────────────
# Settings → Database → Connection string → Transaction pooler (porta 6543)
DATABASE_URL="postgresql://postgres.[REF]:[SENHA]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Settings → Database → Connection string → Session mode (porta 5432)
DIRECT_URL="postgresql://postgres.[REF]:[SENHA]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"

# Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Settings → API → service_role  ⚠️ nunca exponha publicamente
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Claudia Bot (WhatsApp) ───────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# UUID do usuário bot na tabela users (rodar scripts/setup-bot.ts para criar)
BOT_USER_ID=""

# ID do grupo WhatsApp a monitorar — deixe vazio para monitorar todos
# Como obter: rode o bot uma vez, mande msg em qualquer grupo, copie o ID do log
WHATSAPP_GROUP_ID=""
